# ─── Database (Phase 1) ─────────────────────────────────────────────
# Same Postgres host & credentials as the main Momentfy app, but a
# separate database (`portal` by default). Run `pnpm db:migrate` after
# setting this to apply migrations.
DATABASE_URL=postgresql://postgres:password@localhost:5432/portal?schema=public

# ─── Sessions (Phase 1) ─────────────────────────────────────────────
# Random 32-char hex string. Generate with: openssl rand -hex 32
NUXT_SESSION_PASSWORD=change_me_to_a_random_32_char_hex_string
# Set to true when running behind HTTPS (production)
# NUXT_SESSION_COOKIE_SECURE=true

# ─── SMTP (Phase 1 — password reset; Phase 3 — license emails) ──────
# Point at Mailpit (localhost:1025) in dev to capture mail without
# sending. In prod, use Resend SMTP / SendGrid SMTP / your own MTA.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Momentfy <noreply@momentfy.io>"

# ─── Lemon Squeezy (Phase 3) ────────────────────────────────────────
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ─── GitHub (Phase 4) ───────────────────────────────────────────────
# PAT with admin:org scope on the Momentfy org, or fine-grained token
# with Members > Read & write.
GITHUB_TOKEN=
GITHUB_ORG=momentfy
GITHUB_TEAM_SLUG=customers
GITHUB_REPO=momentfy/momentfy

# ─── License pepper (Phase 2) ───────────────────────────────────────
# Extra secret folded into license-key hashing. openssl rand -hex 32
LICENSE_PEPPER=

# ─── Public ─────────────────────────────────────────────────────────
# Where the "Try demo" CTA sends visitors (the live Momentfy app).
NUXT_PUBLIC_DEMO_URL=https://demo.momentfy.com

# Hosted-checkout fallback used by the marketing site until Phase 3
# wires up portal-mediated checkouts.
NUXT_PUBLIC_CHECKOUT_URL=https://momentfy.lemonsqueezy.com

# Public base URL self-hosted Momentfy instances POST to for license
# validation. Used by Phase 5's /api/v1/license/* endpoints.
NUXT_PUBLIC_PORTAL_URL=https://portal.momentfy.io
