# ═══════════════════════════════════════════════════════════════════
#  Momentfy Portal — environment
# ═══════════════════════════════════════════════════════════════════
#
#  Every var below is validated at boot by server/plugins/env-validate.ts:
#    - "required" vars block boot in production (warn in dev)
#    - "optional" vars disable their feature silently at request time
#
#  Copy to .env, fill in real values, then:
#    pnpm install          # generates prisma client (postinstall)
#    pnpm db:migrate       # applies migrations
#    pnpm tsx prisma/seed.ts   # seeds the two Plan rows
#    pnpm dev              # → http://localhost:5173
#
# ═══════════════════════════════════════════════════════════════════


# ─── Runtime (required) ─────────────────────────────────────────────

# Postgres connection string. Same host + creds as the main Momentfy
# app, but a SEPARATE database (`portal` by default) so the portal is
# fully isolated. Example:
#   postgresql://momentfy:secret@db.internal:5432/portal?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/portal?schema=public

# Seals the session cookie. 32-char hex string.
#   openssl rand -hex 32
NUXT_SESSION_PASSWORD=change_me_to_a_random_32_char_hex_string


# ─── Runtime (required in production) ───────────────────────────────

# Standard Node env flag. Set to "production" in prod; leave unset or
# "development" locally.
# NODE_ENV=production

# Set to "true" when served over HTTPS. Without this the session cookie
# won't carry the Secure flag and some browsers will reject it on
# cross-site navigations.
# NUXT_SESSION_COOKIE_SECURE=true

# Extra secret folded into every license-key hash. Rotating this
# invalidates every issued key, so treat it like an encryption key.
#   openssl rand -hex 32
LICENSE_PEPPER=


# ─── Email / SMTP (optional — disables transactional mail when absent) ─
#
# Used by password reset and the "your license is ready" / "invite
# sent" mails on purchase. In dev, point at Mailpit (localhost:1025)
# to inspect messages without actually sending them.

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Momentfy <noreply@momentfy.io>"


# ─── Lemon Squeezy (optional — disables checkout + webhook when absent) ─
#
# Portal-mediated checkout: the server calls LS's /v1/checkouts to
# build a hosted checkout URL with custom_data.account_id pre-bound,
# then 302s the customer. On payment, LS posts to
# /api/webhooks/lemon-squeezy which verifies the signature and issues
# the License.
#
# After filling these in:
#   1) Create a product with two variants in LS (Self-install, Done-for-you).
#   2) `pnpm db:studio` → Plan table → set lsVariantId on each row to the
#      matching LS variant id.
#   3) In the LS dashboard, add a webhook endpoint pointing at
#      https://YOUR_PORTAL/api/webhooks/lemon-squeezy with the shared
#      secret below, subscribed to order_created + order_refunded.

LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Test vs live mode is determined entirely by which API key you use.
# Generate a test-mode key in Settings → API for dev; a live-mode key
# for production. No separate flag is needed (or accepted) on checkouts.


# ─── GitHub (optional — disables repo invites when absent) ──────────
#
# Adds paying customers to a single org team that has read access on
# the source repo. PAT needs `admin:org` (or a fine-grained token with
# Members > Read & write on the org).

GITHUB_TOKEN=
GITHUB_ORG=momentfy
GITHUB_TEAM_SLUG=customers
GITHUB_REPO=momentfy/momentfy


# ─── Public (exposed to client) ─────────────────────────────────────
#
# Variables prefixed with NUXT_PUBLIC_* land in the browser bundle via
# useRuntimeConfig().public. Never put secrets here.

# Where the marketing "Try demo" CTA sends visitors (the live Momentfy
# app instance). Leave as-is if you don't offer a hosted demo.
NUXT_PUBLIC_DEMO_URL=https://demo.momentfy.com

# Fallback hosted-checkout URL used only if the portal-mediated
# /api/portal/checkout endpoint errors (e.g. Plan without lsVariantId).
# Accepts any URL that'll finalise the sale.
NUXT_PUBLIC_CHECKOUT_URL=https://momentfy.lemonsqueezy.com

# Public base URL that self-hosted Momentfy instances POST to for
# license validation. Used:
#   - in the post-purchase email ("open dashboard" link)
#   - as the default redirect_url passed to LS checkouts
#   - embedded into the confirmation email so customers can reach /dashboard
#
# Set this BEFORE going live with phase 3+. Typical value:
#   https://portal.momentfy.io
NUXT_PUBLIC_PORTAL_URL=http://localhost:5173
