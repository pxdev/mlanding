# ═══════════════════════════════════════════════════════════════════
#  Momentfy Portal — local development .env
#
#  The random secrets below are freshly generated and safe to use
#  as-is for local dev. ROTATE ALL OF THEM for production.
#
#  Fill in the marked BLANK lines with credentials only you can
#  provide (GitHub PAT, SMTP account).
# ═══════════════════════════════════════════════════════════════════


# ─── Database ───────────────────────────────────────────────────────
# Same Postgres host/creds as the main Momentfy app, but a SEPARATE
# database called `portal`. Create it:
#     createdb portal
# Then swap USER:PASSWORD below for your actual Postgres creds.
DATABASE_URL=postgresql://postgres:p123321@localhost:5432/portal?schema=public


# ─── Sessions ───────────────────────────────────────────────────────
# Seals the session cookie. 64-char hex string.
# Rotating this immediately signs every active user out.
NUXT_SESSION_PASSWORD=d07eb325afa4b90c767b59b90329226a9e752256346c989e1959e90f3957bf93

# Uncomment in production (behind HTTPS). Sets the `Secure` flag.
# NUXT_SESSION_COOKIE_SECURE=true


# ─── License signing keypair (Ed25519) ──────────────────────────────
# Signs every activation certificate issued to self-hosted installs.
# Losing the PRIVATE key means every future activation is broken until
# a new key is rolled AND the matching public key is shipped in the
# next app release. Keep the private key off version control.
#
# The PUBLIC key is baked into server/utils/license/public-key.ts of
# the self-hosted app at build time — it's duplicated here so the
# portal can self-check at boot.
LICENSE_SIGNING_PRIVATE_KEY=5ca411c5532c6dc038bb291fe793a9fe517b4c5e88dd788f708fec48c7aa5cfc
LICENSE_SIGNING_PUBLIC_KEY=11fc9a50624caa8063dfb3eeb8341728bab74c14209868eb2c9f3f467d73821f


# ─── License pepper ─────────────────────────────────────────────────
# Extra secret folded into every license-key hash. Rotate = every key
# becomes invalid — treat this like an encryption key.
LICENSE_PEPPER=2d8998e029762b0f407630d72cba4fd98ee6500ab21fe29c282aa9c0623b746f


# ─── Email / SMTP ───────────────────────────────────────────────────
# Used by password reset + post-purchase "your license is ready" mails.
# In dev, point at Mailpit (https://github.com/axllent/mailpit) to
# inspect messages without sending:
#     SMTP_HOST=localhost
#     SMTP_PORT=1025
# Leaving SMTP_HOST blank disables transactional email (the server
# logs a no-op message instead).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Momentfy <noreply@momentfy.com>


# ─── Lemon Squeezy ──────────────────────────────────────────────────
# Required for portal-mediated checkout + order webhook.
# Get these from https://app.lemonsqueezy.com → Settings → API.
# Webhook secret is whatever you set when creating the endpoint in LS.
LEMON_SQUEEZY_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9..dkSI6AB1H_Aia4p6wirgVIPnIK6sjSoBLcP3ooVIrqe2JsNKCBaKiYU5GxfctJqGhoz2tnnD0R7SOL94MGRdEmZu1KSS-liiFWacPsD2qAI7QGLuiVcOhsp5mPzx_TMLzBLZlQyJJ_Xmwdgsbn9auj1js4um83mEFxp1HDwEu9uNmEoy73imFDo4Bg9cQllPZj-puwFv-GJw2yXIwPV0YMCCNHyM3hiEQWhOs6NpA5lDgT0cvQLuD4x2YYrKIluqIyOWDn1HYnEA2RgSwSJZqZ6OL8O9BRunX_j8ji_LTCwGAxnZXtNLQgKbIw1GUX-rzSSZv-_GtWscoGtzb0BUDAWgu5oQgfIZgDGKf_NuD9p7vvb8B5OSm55XV58ZevXxEa_V4ddgu50i6DlPAGWUI6GVhNV9C6krJ4Y1PQ8kiimRh9eDuYU6MKBT2fE23iNJQXDG-PSFoo-cgfcUSBE4uphhIM5N2s0OkNCpRdrHhbKGdFoMuhWfFa2T2AES1Rk1vt4wljRlPub9K4luS4GTVubMrYuYt_c_sp1rcKUeQ9EH6reiAOpldCLlCspuXBZQ-oXdB_ts_6eE3BhKCASthCOQXMuGRp0KD852QCLLbstPVfwhpfrI67YjBjFAnC7Hx32zfdyVL6crA0MbFg95S0-sSRL3HoCJ4qFtQWM2hZY
LEMON_SQUEEZY_STORE_ID=233845
LEMON_SQUEEZY_WEBHOOK_SECRET=0JtRcg8mblsUrq7VC8wKnwdcy%

# NOTE: store domain + test-mode are no longer env vars — they're stored in
# the `Setting` table and managed via /admin/settings/integrations.


# ─── GitHub ─────────────────────────────────────────────────────────
# Required to auto-add customers to the source-repo team on purchase.
# Generate a PAT with `admin:org` scope (or a fine-grained token with
# Members > Read & write on your org).
GITHUB_TOKEN=
GITHUB_ORG=momentfy
GITHUB_TEAM_SLUG=customers
GITHUB_REPO=pxdev/momentfy2026


# ─── Bootstrap admins ───────────────────────────────────────────────
# Comma-separated emails auto-promoted to isAdmin on register, and on
# the next login if already registered. Removing an email here does
# NOT demote — use the admin UI (or flip isAdmin manually) to revoke.
# Leave blank to require manual promotion via SQL / Studio.
PORTAL_ADMIN_EMAILS=


# ─── Public (shipped to the browser bundle) ─────────────────────────
# No secrets allowed here — every NUXT_PUBLIC_* variable is inlined
# into the client JS.

# Canonical site URL used for sitemap entries, og:url, canonical links,
# and JSON-LD identity. Override in production deploys.
NUXT_PUBLIC_SITE_URL=https://momentfy.com

# Fallback hosted-checkout URL used only if the portal-mediated
# /api/portal/checkout endpoint fails (e.g. Plan without lsVariantId).
NUXT_PUBLIC_CHECKOUT_URL=https://momentfy.lemonsqueezy.com

# Where the marketing "Try demo" CTA sends visitors.
NUXT_PUBLIC_DEMO_URL=https://momentfy.com/demo

# Public base URL that self-hosted Momentfy instances POST to for
# license validation. Also embedded into the confirmation email
# ("open dashboard" link) and used as the LS checkout redirect_url.
# Update this BEFORE going live.
NUXT_PUBLIC_PORTAL_URL=http://localhost:5173

# Sales WhatsApp number in international format, digits only, NO leading +
# (e.g. 966500000000). Drives the floating chat affordance on the marketing
# layout. Blank = widget renders nothing.
NUXT_PUBLIC_WHATSAPP_NUMBER=


# ─── Marketing / SEO ────────────────────────────────────────────────
# Signs OG image generation requests so a third party can't burn your
# CPU rendering arbitrary images. Generate via:
#     npx nuxt-og-image generate-secret
# Without this, the module logs a warning at boot but still serves
# images on the assumption that you're behind a CDN that caches them.
NUXT_OG_IMAGE_SECRET=


# ─── Node ───────────────────────────────────────────────────────────
# Set to "production" on the deployed host. Leave unset locally.
# NODE_ENV=production
